# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openmanus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# ─── Docker ───────────────────────────────────────────────────────────────────
# Leave blank to use the default socket (/var/run/docker.sock on Linux/Mac)
# On Windows with Docker Desktop: tcp://localhost:2375
DOCKER_HOST=

# ─── CloakBrowser ────────────────────────────────────────────────────────────
CLOAKBROWSER_API_URL=http://localhost:9000
CLOAKBROWSER_API_KEY=

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3000

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
