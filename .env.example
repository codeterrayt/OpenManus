# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openmanus
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Docker ───────────────────────────────────────────────────────────────────
# Leave blank to use the default socket (/var/run/docker.sock on Linux/Mac)
# On Windows with Docker Desktop: tcp://localhost:2375
DOCKER_HOST=

# ─── CloakBrowser ────────────────────────────────────────────────────────────
CLOAKBROWSER_API_URL=http://localhost:9000
CLOAKBROWSER_API_KEY=

# ─── API Server ──────────────────────────────────────────────────────────────
PORT=3000

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_TPM_LIMIT=6000
