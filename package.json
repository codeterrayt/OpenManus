{
  "name": "openmanus",
  "version": "0.1.0",
  "description": "A local-first autonomous AI action engine — Manus clone powered by Ollama.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "ui:dev": "pnpm --filter frontend dev",
    "ui:build": "pnpm --filter frontend build",
    "dev:all": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"magenta,cyan\" \"node --watch src/index.js\" \"pnpm --filter frontend dev\"",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "browser:install": "puppeteer browsers install chrome"
  },
  "puppeteer": {
    "cacheDirectory": "./.browsers"
  },
  "dependencies": {
    "@openai/agents": "^0.0.11",
    "cloakbrowser": "^0.3.31",
    "dockerode": "^4.0.4",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.100.0",
    "pg": "^8.13.3",
    "puppeteer": "^25.1.0",
    "puppeteer-core": "^25.1.0",
    "tar-stream": "^3.1.7",
    "uuid": "^11.1.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "concurrently": "^10.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "",
  "license": "MIT"
}
